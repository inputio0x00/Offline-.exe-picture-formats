{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "img-convert",
  "version": "1.0.0",
  "description": "Native image format converter (JPG/PNG/WEBP/TIFF/HEIF).",
  "dependencies": [
    "libjpeg-turbo",
    "libpng",
    "tiff",
    "libwebp",
    {
      "name": "libheif",
      "features": ["hevc"]
    }
  ]
}
